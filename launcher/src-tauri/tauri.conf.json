{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Vision Dataset Studio",
  "version": "0.1.0",
  "identifier": "studio.vision-dataset.launcher",
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "devUrl": "http://127.0.0.1:8100",
    "frontendDist": "../ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Vision Dataset Studio",
        "width": 1440,
        "height": 920,
        "minWidth": 1024,
        "minHeight": 720,
        "resizable": true,
        "decorations": false,
        "transparent": true,
        "dragDropEnabled": false,
        "fullscreen": false
      },
      {
        "label": "terminal",
        "url": "terminal.html",
        "title": "Vision Dataset Studio Terminal",
        "width": 920,
        "height": 560,
        "minWidth": 680,
        "minHeight": 420,
        "center": true,
        "resizable": true,
        "decorations": false,
        "transparent": false,
        "dragDropEnabled": false,
        "visible": false,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.ico",
      "icons/icon-512.png",
      "icons/icon.png"
    ]
  }
}
